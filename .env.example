# ============================================
# AI Coder Quest - 环境变量配置
# 复制此文件为 .env.local 并填入你的值
# cp .env.example .env.local
# ============================================

# Supabase (数据库 + 存储)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Better Auth 数据库连接（使用 Supabase PostgreSQL Pooler）
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub OAuth
# 创建应用: https://github.com/settings/developers
# 回调地址: http://localhost:3000/api/auth/callback/github (开发环境)
# 回调地址: https://your-domain.vercel.app/api/auth/callback/github (生产环境)
AUTH_GITHUB_ID=your-github-oauth-app-client-id
AUTH_GITHUB_SECRET=your-github-oauth-app-client-secret
